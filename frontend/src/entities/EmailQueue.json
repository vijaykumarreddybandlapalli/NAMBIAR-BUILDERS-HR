{
  "name": "EmailQueue",
  "type": "object",
  "properties": {
    "recipient_email": {
      "type": "string",
      "title": "Recipient Email"
    },
    "recipient_name": {
      "type": "string",
      "title": "Recipient Name"
    },
    "subject": {
      "type": "string",
      "title": "Subject"
    },
    "body": {
      "type": "string",
      "title": "Body"
    },
    "email_type": {
      "type": "string",
      "enum": [
        "birthday",
        "anniversary",
        "welcome",
        "event",
        "festival"
      ],
      "title": "Email Type"
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "sent",
        "delivered",
        "failed"
      ],
      "title": "Status"
    },
    "scheduled_date": {
      "type": "string",
      "format": "date-time",
      "title": "Scheduled Date"
    },
    "sent_date": {
      "type": "string",
      "format": "date-time",
      "title": "Sent Date"
    },
    "error_message": {
      "type": "string",
      "title": "Error Message"
    }
  },
  "required": [
    "recipient_email",
    "recipient_name",
    "subject",
    "email_type",
    "status"
  ]
}