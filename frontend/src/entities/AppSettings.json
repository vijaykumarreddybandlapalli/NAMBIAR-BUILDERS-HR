{
  "name": "AppSettings",
  "type": "object",
  "properties": {
    "primary_from_email": {
      "type": "string",
      "title": "Primary From Email"
    },
    "secondary_from_email": {
      "type": "string",
      "title": "Secondary From Email"
    },
    "bcc_emails": {
      "type": "string",
      "title": "BCC Emails (comma separated)"
    },
    "send_time": {
      "type": "string",
      "title": "Scheduled Send Time (HH:MM)"
    },
    "auto_birthday_wishes": {
      "type": "boolean",
      "title": "Auto Send Birthday Wishes"
    },
    "auto_anniversary_wishes": {
      "type": "boolean",
      "title": "Auto Send Anniversary Wishes"
    },
    "welcome_mail_day": {
      "type": "string",
      "enum": [
        "monday",
        "tuesday",
        "wednesday",
        "thursday",
        "friday",
        "saturday",
        "sunday"
      ],
      "title": "Welcome Mail Day"
    }
  },
  "required": [
    "primary_from_email"
  ]
}